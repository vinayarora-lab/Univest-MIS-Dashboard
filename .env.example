# Zoho OAuth Credentials
# Get these from: https://api-console.zoho.com/
ZOHO_CLIENT_ID=your_client_id_here
ZOHO_CLIENT_SECRET=your_client_secret_here
ZOHO_REFRESH_TOKEN=your_refresh_token_here

# Zoho Books Organization ID
# Find it at: https://books.zoho.com/app#/settings/organization
ZOHO_ORGANIZATION_ID=your_organization_id_here

# Zoho API Region (com | in | eu | com.au | jp)
# Use 'in' for India, 'eu' for Europe, etc.
ZOHO_REGION=com

# Report Date Range (YYYY-MM-DD format)
FROM_DATE=2024-04-01
TO_DATE=2025-03-31

# Output format: json | csv | excel | all
OUTPUT_FORMAT=all

# Output directory for reports
OUTPUT_DIR=./reports
